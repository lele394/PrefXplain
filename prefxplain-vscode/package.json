{
  "name": "prefxplain-vscode",
  "displayName": "PrefXplain Preview",
  "description": "Opens prefxplain.html in a clean webview tab with no toolbar, no URL bar, and auto-refresh on file change.",
  "publisher": "prefxplain",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Other"],
  "main": "./out/extension.js",
  "activationEvents": [
    "onCommand:prefxplain.preview",
    "onCommand:prefxplain.generate",
    "onUri"
  ],
  "contributes": {
    "commands": [
      {
        "command": "prefxplain.preview",
        "title": "PrefXplain: Preview diagram"
      },
      {
        "command": "prefxplain.generate",
        "title": "PrefXplain: Generate diagram"
      }
    ],
    "configuration": {
      "title": "PrefXplain",
      "properties": {
        "prefxplain.model": {
          "type": "string",
          "default": "",
          "description": "LLM model name passed to prefxplain via --model (for example: llama3.1:8b)."
        },
        "prefxplain.ollama.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Use local/remote Ollama via --ollama."
        },
        "prefxplain.ollama.host": {
          "type": "string",
          "default": "127.0.0.1",
          "description": "Ollama server IP/domain passed via --ollama-host."
        },
        "prefxplain.ollama.port": {
          "type": "number",
          "default": 11434,
          "minimum": 1,
          "maximum": 65535,
          "description": "Ollama server port passed via --ollama-port."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}
