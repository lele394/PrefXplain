#!/usr/bin/env bash
# PrefXplain installer — git clone + ./setup, gstack-style.
#
# What this does:
#   1. Builds a local virtualenv so we don't touch system Python.
#   2. Installs prefxplain (editable) + runtime deps into that venv.
#   3. Drops a shell wrapper in ~/.local/bin so `prefxplain` works globally.
#   4. Calls `prefxplain setup` to register /prefxplain with every detected
#      AI coding tool (Claude Code / Cursor / Codex / Copilot / Gemini)
#      AND auto-install the VS Code / Cursor / Windsurf preview extension.

set -euo pipefail

GREEN=$'\033[0;32m'
YELLOW=$'\033[1;33m'
RED=$'\033[0;31m'
BOLD=$'\033[1m'
DIM=$'\033[2m'
NC=$'\033[0m'

REPO_ROOT="$(cd "$(dirname "$0")" && pwd)"

echo "${BOLD}PrefXplain setup${NC}"
echo "${DIM}Source: $REPO_ROOT${NC}"
echo

# 1. Python check
if ! command -v python3 >/dev/null 2>&1; then
  echo "${RED}✗${NC} Python 3 not found."
  echo "  Install Python 3.9+ first:"
  echo "    macOS:  brew install python"
  echo "    Linux:  sudo apt install python3 python3-venv   (or equivalent)"
  exit 1
fi

PY_VERSION=$(python3 -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}")')
PY_OK=$(python3 -c 'import sys; print("1" if sys.version_info >= (3, 9) else "0")')
if [ "$PY_OK" != "1" ]; then
  echo "${RED}✗${NC} Python $PY_VERSION is too old. Need 3.9+."
  exit 1
fi
echo "${GREEN}✓${NC} Python $PY_VERSION"

# 2. Build isolated venv
VENV="$REPO_ROOT/.venv"
if [ ! -d "$VENV" ]; then
  python3 -m venv "$VENV"
fi

"$VENV/bin/pip" install --quiet --upgrade pip >/dev/null
"$VENV/bin/pip" install --quiet -e "$REPO_ROOT" >/dev/null
echo "${GREEN}✓${NC} Installed prefxplain into $VENV"

# 3. Expose `prefxplain` on PATH via a shim in ~/.local/bin.
BIN_DIR="${PREFXPLAIN_BIN_DIR:-$HOME/.local/bin}"
mkdir -p "$BIN_DIR"
SHIM="$BIN_DIR/prefxplain"
cat > "$SHIM" <<EOF
#!/usr/bin/env bash
exec "$VENV/bin/prefxplain" "\$@"
EOF
chmod +x "$SHIM"
echo "${GREEN}✓${NC} Linked: $SHIM"

case ":$PATH:" in
  *":$BIN_DIR:"*) ;;
  *)
    echo
    echo "${YELLOW}⚠${NC}  $BIN_DIR is not on your PATH."
    echo "   Add this line to ~/.zshrc (or ~/.bashrc), then reopen your shell:"
    echo "     ${BOLD}export PATH=\"\$HOME/.local/bin:\$PATH\"${NC}"
    ;;
esac

# 4. Ensure the VS Code-family preview extension is bundled and ready to
#    install. If no prebuilt VSIX exists yet and Node is available, build it.
EXT_DIR="$REPO_ROOT/prefxplain-vscode"
PKG_EXT_DIR="$REPO_ROOT/prefxplain/vscode_extension"
mkdir -p "$PKG_EXT_DIR"
if [ -d "$EXT_DIR" ]; then
  if ! ls "$EXT_DIR"/*.vsix >/dev/null 2>&1 && command -v npm >/dev/null 2>&1; then
    echo
    echo "${BOLD}Building preview extension…${NC}"
    (
      cd "$EXT_DIR"
      npm install --silent >/dev/null 2>&1 || true
      npm run compile --silent >/dev/null 2>&1 || true
      npx --yes @vscode/vsce package --allow-missing-repository >/dev/null 2>&1 || true
    )
  fi

  if ls "$EXT_DIR"/*.vsix >/dev/null 2>&1; then
    LATEST_VSIX="$(ls -t "$EXT_DIR"/*.vsix | head -1)"
    cp -f "$LATEST_VSIX" "$PKG_EXT_DIR/"
    echo "${GREEN}✓${NC} Bundled preview extension: $PKG_EXT_DIR/$(basename "$LATEST_VSIX")"
  elif ls "$PKG_EXT_DIR"/*.vsix >/dev/null 2>&1; then
    echo "${GREEN}✓${NC} Bundled preview extension: $(ls -t "$PKG_EXT_DIR"/*.vsix | head -1)"
  else
    echo "${YELLOW}⚠${NC}  Preview extension artifact is missing. In-IDE preview/editing will not work until a .vsix is built."
  fi
fi

# 5. Register /prefxplain for every AI tool found + install VS Code extension.
echo
echo "${BOLD}Registering /prefxplain…${NC}"
"$VENV/bin/prefxplain" setup

echo
echo "${BOLD}${GREEN}Done.${NC}"
echo "   Type ${BOLD}/prefxplain${NC} inside your AI coding tool."
echo "   Or run ${BOLD}prefxplain create .${NC} directly in any repo."
